x = "Age",
y = "Prevalence",
color = "Period"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5),
legend.position = "bottom"
)
############### Generating estimates for the LC-SC model #########################
#### estimating the L-APCH model according to Fosse and Winship with period slope fixed to zero for identification #####
# setting up the weighted polynomial constrasts #
contrasts(data3$agerec1)<-contr.poly.weighted(data3$agerec1, width=3)
contrasts(data3$period)<-contr.poly.weighted(data3$period,width=3)
contrasts(data3$cohort)<-contr.poly.weighted(data3$cohort, width=3)
contrasts(data3$period)[, 1] <- 0  ###### setting the linear contrast for period to zero for identification
# declare survey design for sampling weight
survey.design <- svydesign(id = ~1, weights = ~normwt, strata= ~strata, data = data3)
# model with age, cohort (linear and non-linear parameters) and period (non-linear) parameters
results3<-svyglm(alcdis3 ~ agerec1 + cohort + period, design=survey.design, family=quasibinomial())
summary(results3)
# Tidy the summary output
model_tidy3 <- broom::tidy(results3, conf.int = TRUE, exponentiate = TRUE)
# Create a table using gt
reg_table3<- model_tidy3 %>%
gt() %>%
tab_header(
title = "Survey-Weighted Logistic Regression Model",
subtitle = "Dependent Variable: Low alcohol use and high distress"
) %>%
fmt_number(
columns = c(estimate, std.error, statistic, p.value, conf.low, conf.high),
decimals = 3
) %>%
cols_label(
term = "Predictor",
estimate = "Estimate",
std.error = "Std. Error",
statistic = "t-value",
p.value = "p-value",
conf.low = "Lower 95% CI",
conf.high = "Upper 95% CI"
)
# get deviations from linear trend and age/cohort linear effects
A.nonlin <- get_deviations_w_intercept(results3, "^agerec1", contrasts(data3$agerec1))
C.nonlin <- get_deviations_w_intercept(results3, "^cohort", contrasts(data3$cohort))
extract_coefs <- coef(results3)[grepl("^period", names(coef(results3)))]
extract_coefs <- c(0, extract_coefs)
P.nonlin <-  coef(results3)[1] + contrasts(data3$period)  %*% extract_coefs
devnoint_age <- get_deviations(results3, "^agerec1", contrasts(data3$agerec1))
devnoint_period <- get_deviations(results3, "^period", contrasts(data3$period))
devnoint_cohort <- get_deviations(results3, "^cohort", contrasts(data3$cohort))
theta1 <- coef(results3)["agerec1.L"]
theta2 <- coef(results3)["cohort.L"]
## generate overall age period and cohort effects - combination of linear and non-linear trends
intercept <- coef(results3)[1]
matA <- contrasts(data3$agerec1)
matP <- contrasts(data3$period)
matC <- contrasts(data3$cohort)
AgeDeviations <- data.frame(Age=levels(data3$agerec1), Deviations=devnoint_age)
PeriodDeviations <- data.frame(Period=levels(data3$period), Deviations=devnoint_period)
CohortDeviations <- data.frame(Cohort=levels(data3$cohort), Deviations=devnoint_cohort)
AgeEffects <- AgeDeviations
PeriodEffects <- PeriodDeviations
CohortEffects <- CohortDeviations
AgeEffects$Effect <-
intercept + theta1 * matA[, 1] + AgeDeviations$Deviations
PeriodEffects$Effect <-
0 * matP[, 1] + PeriodDeviations$Deviations
CohortEffects$Effect <-
intercept + theta2 * matC[, 1] + CohortDeviations$Deviations
### add in the confidence intervals around the overall age, period and cohort trends
# extract vcov parameters for age
vcov_matrix <- vcov(results3)
parameter_names <- rownames(vcov_matrix)
selected_params_age <- c("(Intercept)",parameter_names[grepl("^agerec1", parameter_names)])
vcov_matrix_age <- vcov_matrix[selected_params_age, selected_params_age, drop = FALSE]
selected_params_period <- c(parameter_names[grepl("^period", parameter_names)])
vcov_matrix_period <- vcov_matrix[selected_params_period, selected_params_period, drop = FALSE]
selected_params_cohort<- c("(Intercept)",parameter_names[grepl("^cohort", parameter_names)])
vcov_matrix_cohort <- vcov_matrix[selected_params_cohort, selected_params_cohort, drop = FALSE]
#create design matrix for age based on polynomial coefficients extracted from full model
age_design_matrix_with_intercept <- cbind(Intercept = 1, matA)
period_design_matrix_with_intercept <- cbind(matP[,2:5])
cohort_design_matrix_with_intercept <- cbind(Intercept = 1, matC)
# generate standard errors by using design matrix for age, period, cohort and extracted vcov matrix
AgeEffects$std_errors <- sqrt(rowSums((age_design_matrix_with_intercept %*% vcov_matrix_age) * age_design_matrix_with_intercept))
PeriodEffects$std_errors <- sqrt(rowSums((period_design_matrix_with_intercept %*% vcov_matrix_period) * period_design_matrix_with_intercept))
CohortEffects$std_errors <- sqrt(rowSums((cohort_design_matrix_with_intercept %*% vcov_matrix_cohort) * cohort_design_matrix_with_intercept))
# generate normal approximation of 95% confidence intervals for the extracted age effects
z_value <- qnorm(0.975)
AgeEffects$lower_bound <- AgeEffects$Effect - z_value * AgeEffects$std_errors
AgeEffects$upper_bound <- AgeEffects$Effect + z_value * AgeEffects$std_errors
PeriodEffects$lower_bound <- PeriodEffects$Effect - z_value * PeriodEffects$std_errors
PeriodEffects$upper_bound <- PeriodEffects$Effect + z_value * PeriodEffects$std_errors
CohortEffects$lower_bound <- CohortEffects$Effect - z_value * CohortEffects$std_errors
CohortEffects$upper_bound <- CohortEffects$Effect + z_value * CohortEffects$std_errors
###### plotting effects ########
# LC or overall intracohort trends (overall LC that account for linear and non-linear effects of age)
lc_plot3 <- tibble(effect = c(invlogit(AgeEffects$Effect)),
age = AgeEffects$Age,
which = c(rep("Age", length(AgeEffects$Effect))),
lower = plogis(AgeEffects$lower_bound),
upper = plogis(AgeEffects$upper_bound)) %>%
mutate(which = factor(which, levels = c("Age"))) %>%
ggplot(aes(x = age, y = effect, group = which, linetype = which)) +
geom_point() + geom_line() +
#  scale_y_continuous(limits = c(0, 0.25))+
geom_ribbon(aes(ymin = lower, ymax = upper), fill = "blue", alpha = 0.3) +
labs(y = "Predicted probability", x = "Age", group = "", linetype = "") +
theme_bw()+
theme(legend.position="none")
lc_plot3
# SC or overall intercohort trends (overall SC that account for linear and non-linear effects of cohort)
sc_plot3 <- tibble(effect = c(invlogit(CohortEffects$Effect)),
cohort = CohortEffects$Cohort,
which = c(rep("Cohort", length(CohortEffects$Effect))),
lower = plogis(CohortEffects$lower_bound),
upper = plogis(CohortEffects$upper_bound)) %>%
mutate(which = factor(which, levels = c("Cohort"))) %>%
ggplot(aes(x = cohort, y = effect, group = which, linetype = which)) +
geom_point() + geom_line() +
#  scale_y_continuous(limits = c(0, 0.25))+
geom_ribbon(aes(ymin = lower, ymax = upper), fill = "blue", alpha = 0.3) +
labs(y = "Predicted probability", x = "Cohort", group = "", linetype = "") +
theme_bw()+
theme(legend.position="none")
sc_plot3
# Period non-linearities or flucuations
per_plot3 <- tibble(effect = c(PeriodEffects$Effect),
period = PeriodEffects$Period,
which = c(rep("Period", length(PeriodEffects$Effect))),
lower = PeriodEffects$lower_bound,
upper = PeriodEffects$upper_bound) %>%
mutate(which = factor(which, levels = c("Period"))) %>%
ggplot(aes(x = period, y = effect, group = which, linetype = which)) +
geom_point() + geom_line() +
geom_ribbon(aes(ymin = lower, ymax = upper), fill = "blue", alpha = 0.3) +
labs(y = "Predicted probability", x = "Period", group = "", linetype = "") +
theme_bw()+
theme(legend.position="none")
per_plot3
######### incorporating the period fluctuations in the LC and SC estimates #########
########### THE HEATMAPS NOW WORK ################
# extracting coefficients from full model
coef_age <- coef(results3)[grepl("^agerec1", names(coef(results3)))]
coef_cohort <- coef(results3)[grepl("^cohort", names(coef(results3)))]
coef_period <- coef(results3)[grepl("^period", names(coef(results3)))]
coef_period <- c(0, coef_period)
# creating new dataset that contains crossed combinations of age, period, and cohort
newdata4 <- expand.grid(
age = levels(data3$agerec1),
period = levels(data3$period)
)
newdata4$cohort <- as.numeric(as.character(newdata4$period)) - as.numeric(as.character(newdata4$age))
newdata4$cohort <-factor(newdata4$cohort)
contrasts(newdata4$age) <- contrasts(data3$agerec1)
contrasts(newdata4$period) <- contrasts(data3$period)
contrasts(newdata4$cohort) <- contrasts(data3$cohort)
design_matrix4 <- model.matrix(~ age + period + cohort, data = newdata4)
newdata4$predicted_value <-   + design_matrix4 %*%
c(intercept, coef_age, coef_period, coef_cohort)
newdata4$predicted_probability <- plogis(newdata4$predicted_value)
#creating new dataset that contains crossed combinations of age and period
newdata1 <- expand.grid(
age = levels(data3$agerec1),
period = levels(data3$period)
)
contrasts(newdata1$age) <- contrasts(data3$agerec1)
contrasts(newdata1$period) <- contrasts(data3$period)
