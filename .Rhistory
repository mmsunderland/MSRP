geom_tile() +
scale_fill_gradient(low = "blue", high = "red", name = "Low alcohol use low distress") +
labs(title = "Heatmap of Low alcohol use low distress", x = "Period (Year)", y = "Age (Years)") +
theme_minimal()
### plot for the adjusted local LC trend ###
local_lc_plot4 <- ggplot(newdata1, aes(x = period, y = age, fill = predicted_probability)) +
geom_tile() +
scale_fill_gradient(low = "red", high = "blue", name = "Low alcohol use low distress") +
labs(title = "Heatmap of Low alcohol use low distress", x = "Period (Year)", y = "Age (Years)") +
theme_minimal()
## plot for the adjusted local SC trend ###
local_sc_plot4 <- ggplot(newdata2, aes(x = period, y = age, fill = predicted_probability)) +
geom_tile() +
scale_fill_gradient(low = "red", high = "blue", name = "Low alcohol use low distress") +
labs(title = "Heatmap of Low alcohol use low distress", x = "Period (Year)", y = "Age (Years)") +
theme_minimal()
################ COMBINED TABLES AND PLOTS ####################
html_output <- tagList(
reg_table1 %>% as_raw_html(),
reg_table2 %>% as_raw_html(),
reg_table3 %>% as_raw_html(),
reg_table4 %>% as_raw_html()
)
# Save as an HTML file
save_html(html_output, file = "combined_tables.html")
combined_plot_lc <- (lc_plot1 | lc_plot2) / (lc_plot3 | lc_plot4)
ggsave("combined_plot_lc.png")
combined_plot_sc <- (sc_plot1 | sc_plot2) / (sc_plot3 | sc_plot4)
ggsave("combined_plot_sc.png")
combined_plot_local_lc <- (local_lc_plot1 | local_lc_plot2) / (local_lc_plot3 | local_lc_plot4)
ggsave("combined_plot_local_lc.png")
combined_plot_local_sc <- (local_sc_plot1 | local_sc_plot2) / (local_sc_plot3 | local_sc_plot4)
ggsave("combined_plot_local_sc.png")
combined_plot_lc
combined_plot_sc
combined_plot_local_lc
combined_plot_local_sc
combined_plot_sc
combined_plot_lc
combined_plot_local_lc
combined_plot_local_sc
